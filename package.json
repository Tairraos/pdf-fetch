{
  "name": "pdf-fetch",
  "version": "0.1.0",
  "description": "使用 ImageMagick 将 PDF 页面批量导出为 JPG 的命令行工具（CLI 命令：pdf2jpg）",
  "keywords": [
    "pdf",
    "jpg",
    "imagemagick",
    "cli"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Tairraos/pdf-fetch.git"
  },
  "homepage": "https://github.com/Tairraos/pdf-fetch",
  "bugs": {
    "url": "https://github.com/Tairraos/pdf-fetch/issues"
  },
  "main": "dist/cli.js",
  "bin": {
    "pdf2jpg": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepublishOnly": "pnpm run lint && pnpm run typecheck && pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.5",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
